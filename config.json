{
    "SharePath": "\\\\SERVER\\Share",

    "MaxPathLength": 256,
    "WarnAtRemaining": 30,

    "StaleFileDays": 180,
    "ArchiveFolderName": "_Archive",
    "AutoArchive": false,

    "LogDirectory": "C:\\ShareWatcher\\Logs",

    "ExcludeFolders": [
        "System Volume Information",
        "$RECYCLE.BIN"
    ],

    "IgnoreGroups": [
        "Domain Admins",
        "Enterprise Admins",
        "Schema Admins",
        "Backup Operators"
    ]
}